---
- name: Deploy and Run Enhanced Scanner on Multiple Servers
  hosts: all
  gather_facts: yes
  vars:
    # Configuration options
    config_file_src: "files/scan_config.json"
    config_file_dest: "/tmp/scan_config.json"
    script_src: "files/enhanced_checksum_scanner.py"
    script_dest: "/tmp/enhanced_scanner.py"
    manifest_dest: "/tmp/manifest_{{ ansible_hostname }}_{{ ansible_date_time.epoch }}.json"
    
    # Server identification
    server_role: "{{ 'prod' if 'prod' in group_names else 'staging' }}"
    server_tags:
      - "{{ ansible_distribution | lower }}"
      - "{{ ansible_architecture }}"
      - "{{ 'rhel' if ansible_os_family == 'RedHat' else 'other' }}"
    
    # Scan options
    include_metadata: true
    scan_format: "json"
    
  tasks:
    - name: Create temporary directory
      tempfile:
        state: directory
        suffix: "_scanner"
      register: temp_dir
    
    - name: Deploy scanner script
      copy:
        src: "{{ script_src }}"
        dest: "{{ script_dest }}"
        mode: '0755'
    
    - name: Deploy configuration file
      copy:
        src: "{{ config_file_src }}"
        dest: "{{ config_file_dest }}"
      when: config_file_src is defined
    
    - name: Execute enhanced scanner
      command: >
        python3 {{ script_dest }}
        {% if config_file_src is defined %}
        --config {{ config_file_dest }}
        {% else %}
        --paths {{ app_directories | join(' ') }}
        --exclude {{ exclude_patterns | join(' ') }}
        {% endif %}
        --output {{ manifest_dest }}
        --format {{ scan_format }}
        --server-name {{ ansible_hostname }}
        --server-role {{ server_role }}
        --tags {{ server_tags | join(' ') }}
        {% if not include_metadata %}
        --no-metadata
        {% endif %}
      register: scan_result
      changed_when: false
      timeout: 3600  # 1 hour timeout for large scans
    
    - name: Display scan results
      debug:
        msg: |
          Server: {{ ansible_hostname }}
          Status: {{ 'Success' if scan_result.rc == 0 else 'Failed' }}
          Files Processed: {{ scan_result.stderr_lines | select('match', '.*Processed:.*') | first | default('Unknown') }}
          Errors: {{ scan_result.stderr_lines | select('match', '.*Errors:.*') | first | default('0') }}
    
    - name: Fetch manifest to control node
      fetch:
        src: "{{ manifest_dest }}"
        dest: "./manifests/"
        flat: yes
        fail_on_missing: yes
    
    - name: Cleanup temporary files
      file:
        path: "{{ item }}"
        state: absent
      loop:
        - "{{ script_dest }}"
        - "{{ config_file_dest }}"
        - "{{ manifest_dest }}"
      when: cleanup_temp_files | default(true)

- name: Compare Manifests with Metadata
