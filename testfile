import asyncio
import subprocess
import os
import json
from fastapi import FastAPI, HTTPException
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel
from typing import Optional, List
from dotenv import load_dotenv

# Load environment variables
load_dotenv()

app = FastAPI(title="Copilot CLI API", description="API for GitHub Copilot CLI integration")

# Configure CORS for React frontend (running on port 5173)
app.add_middleware(
    CORSMiddleware,
    allow_origins=["http://localhost:5173", "http://127.0.0.1:5173"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# Request/Response Models
class ChatRequest(BaseModel):
    message: str
    session_id: Optional[str] = None

class ChatResponse(BaseModel):
    response: str
    session_id: str
    error: Optional[str] = None

class HealthResponse(BaseModel):
    status: str
    copilot_available: bool

# Configuration from environment variables
COPILOT_PATH = os.getenv("COPILOT_PATH", "copilot")  # or full path on Windows: "C:\\Users\\yourname\\AppData\\Roaming\\npm\\copilot.cmd"
TIMEOUT_SECONDS = int(os.getenv("TIMEOUT_SECONDS", "60"))

# Helper function to run Copilot CLI command
async def run_copilot_command(prompt: str) -> tuple[str, bool]:
    """
    Run GitHub Copilot CLI with the given prompt.
    Returns (response, success_flag)
    """
    try:
        # Build the command
        # Using 'gh copilot suggest' command which takes a prompt
        command = [COPILOT_PATH, "suggest", prompt]
        
        # Run subprocess with timeout
        process = await asyncio.create_subprocess_exec(
            *command,
            stdout=asyncio.subprocess.PIPE,
            stderr=asyncio.subprocess.PIPE
        )
        
        try:
            stdout, stderr = await asyncio.wait_for(
                process.communicate(), 
                timeout=TIMEOUT_SECONDS
            )
        except asyncio.TimeoutError:
            process.kill()
            await process.wait()
            return "", False
        
        if process.returncode == 0:
            response = stdout.decode('utf-8').strip()
            return response, True
        else:
            error_msg = stderr.decode('utf-8').strip()
            return error_msg, False
            
    except FileNotFoundError:
        return "GitHub Copilot CLI not found. Please ensure it's installed and in PATH.", False
    except Exception as e:
        return str(e), False

# Alternative: Using headless mode API endpoint
# If you have copilot running in headless mode on port 4321, use this instead
async def call_headless_copilot(prompt: str) -> tuple[str, bool]:
    """
    Call Copilot running in headless mode on port 4321.
    Use this if you have 'copilot --headless --port 4321 --model gpt-4.1' running.
    """
    import httpx
    
    try:
        async with httpx.AsyncClient() as client:
            response = await client.post(
                "http://localhost:4321/v1/chat/completions",
                json={
                    "messages": [{"role": "user", "content": prompt}],
                    "stream": False
                },
                timeout=TIMEOUT_SECONDS
            )
            
            if response.status_code == 200:
                data = response.json()
                return data.get("choices", [{}])[0].get("message", {}).get("content", ""), True
            else:
                return f"Error: {response.status_code}", False
    except Exception as e:
        return str(e), False

# API Endpoints
@app.get("/health", response_model=HealthResponse)
async def health_check():
    """Check if API and Copilot are available"""
    try:
        # Test if copilot command exists
        process = await asyncio.create_subprocess_exec(
            COPILOT_PATH, "--version",
            stdout=asyncio.subprocess.PIPE,
            stderr=asyncio.subprocess.PIPE
        )
        await process.wait()
        copilot_available = (process.returncode == 0)
    except:
        copilot_available = False
    
    return HealthResponse(
        status="healthy",
        copilot_available=copilot_available
    )

@app.post("/api/chat", response_model=ChatResponse)
async def chat(request: ChatRequest):
    """
    Send a message to GitHub Copilot and get a response.
    """
    if not request.message:
        raise HTTPException(status_code=400, detail="Message cannot be empty")
    
    # Choose which method to use
    # Option 1: Direct CLI command (no persistent server needed)
    response_text, success = await run_copilot_command(request.message)
    
    # Option 2: If using headless mode on port 4321, uncomment this:
    # response_text, success = await call_headless_copilot(request.message)
    
    session_id = request.session_id or f"session_{id(request)}"
    
    return ChatResponse(
        response=response_text if success else f"Error: {response_text}",
        session_id=session_id,
        error=None if success else response_text
    )

@app.post("/api/chat/stream")
async def chat_stream(request: ChatRequest):
    """
    Stream response from GitHub Copilot (Server-Sent Events).
    """
    from fastapi.responses import StreamingResponse
    import time
    
    async def generate():
        # Simulate streaming for now
        # For full streaming, you'd need to parse Copilot's streaming output
        response_text, success = await run_copilot_command(request.message)
        
        # Send chunks (simulated)
        for word in response_text.split():
            yield f"data: {json.dumps({'token': word, 'done': False})}\n\n"
            await asyncio.sleep(0.05)
        
        yield f"data: {json.dumps({'token': '', 'done': True})}\n\n"
    
    return StreamingResponse(
        generate(),
        media_type="text/event-stream",
        headers={
            "Cache-Control": "no-cache",
            "Connection": "keep-alive",
        }
    )

if __name__ == "__main__":
