#!/bin/bash
# Best Performance for Huge Directories (500K+ files)

WORK_DIR="/path/to/parent/dir"  # CHANGE THIS TO YOUR ACTUAL PATH
TEMP_BASE="/tmp/file_checksums_$$"

export -f process
process() {
    file="$1"
    cksum_out=$(cksum "$file")
    csum=${cksum_out%% *}
    size=$(echo $cksum_out | awk '{print $2}')
    owner=$(stat -c "%U" "$file")
    ts=$(stat -c "%y" "$file" | cut -d' ' -f1,2 | cut -d'.' -f1 | sed 's/\([0-9]\{4\}\)-\([0-9]\{2\}\)-\([0-9]\{2\}\)/\2-\3-\1/')
    echo "$file|$owner|$size|$ts|$csum"
}
export -f process

# Process files in parallel (4 cores)
find "$WORK_DIR" -type f -print0 | xargs -0 -P 4 -n 50 bash -c 'for f; do process "$f"; done' _
