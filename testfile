#!/usr/bin/env python3
"""
compare_with_metadata.py - Compare manifests including timestamps and ownership
"""

import json
import argparse
from datetime import datetime
from collections import defaultdict
from typing import Dict, List, Any, Tuple
import os

class MetadataComparer:
    def __init__(self):
        self.servers = {}
        self.all_files = set()
        
    def load_manifests(self, manifest_paths: List[str]) -> Dict[str, Dict]:
        """Load all manifest files"""
        for path in manifest_paths:
            with open(path, 'r') as f:
                data = json.load(f)
                server_name = data['metadata']['server'].get('hostname', os.path.basename(path))
                self.servers[server_name] = data
                self.all_files.update(data['manifest'].keys())
        return self.servers
    
    def compare_metadata(self, file_path: str, metadata_by_server: Dict) -> Dict:
        """Compare all metadata aspects for a file"""
        comparison = {
            "checksum_match": True,
            "size_match": True,
            "owner_match": True,
            "group_match": True,
            "mode_match": True,
            "mtime_match": True,
            "differences": []
        }
        
        servers = list(metadata_by_server.keys())
        if len(servers) < 2:
            return comparison
        
        # Compare each metadata field
        reference = metadata_by_server[servers[0]]
        
        for server in servers[1:]:
            current = metadata_by_server[server]
            
            if reference['checksum'] != current['checksum']:
                comparison['checksum_match'] = False
                comparison['differences'].append(f"Checksum differs: {server}")
            
            if reference.get('size', -1) != current.get('size', -1):
                comparison['size_match'] = False
                comparison['differences'].append(f"Size differs: {server}")
            
            if reference.get('owner', '') != current.get('owner', ''):
                comparison['owner_match'] = False
                comparison['differences'].append(
                    f"Owner differs: {server} ({current.get('owner')} vs {reference.get('owner')})"
                )
            
            if reference.get('group', '') != current.get('group', ''):
                comparison['group_match'] = False
                comparison['differences'].append(
                    f"Group differs: {server} ({current.get('group')} vs {reference.get('group')})"
                )
            
            if reference.get('mode', '') != current.get('mode', ''):
                comparison['mode_match'] = False
                comparison['differences'].append(
                    f"Permissions differ: {server} ({current.get('mode')} vs {reference.get('mode')})"
                )
            
            # Compare mtime with tolerance (1 second)
            if abs(reference.get('mtime', 0) - current.get('mtime', 0)) > 1:
                comparison['mtime_match'] = False
                comparison['differences'].append(
                    f"Modification time differs: {server} "
                    f"({current.get('mtime_iso')} vs {reference.get('mtime_iso')})"
                )
        
        return comparison
    
