        # Summary statistics
        html.append("<h2>Comparison Summary</h2>")
        html.append("<div class='summary'>")
        html.append(f"<p>Total unique files: {len(self.all_files)}</p>")
        html.append(f"<p>✅ Matching files: {len(results['matching'])}</p>")
        html.append(f"<p>❌ Files with mismatches: {len(results['mismatched'])}</p>")
        
        for server, files in results['unique_files'].items():
            if files:
                html.append(f"<p>📁 Files only on {server}: {len(files)}</p>")
        html.append("</div>")
        
        # Mismatched files details
        if results['mismatched']:
            html.append("<h2>Files with Differences</h2>")
            html.append("<table>")
            html.append("<tr><th>File Path</th><th>Differences</th><th>Details</th></tr>")
            
            for item in results['mismatched'][:100]:
                html.append("<tr>")
                html.append(f"<td>{item['path']}</td>")
                html.append(f"<td>{', '.join(item['comparison']['differences'][:3])}</td>")
                
                # Detailed metadata
                html.append("<td><div class='metadata-details'>")
                for server, metadata in item['metadata'].items():
                    html.append(f"<span class='server-badge'>{server}</span> ")
                    if isinstance(metadata, dict):
                        html.append(f"Owner: {metadata.get('owner', 'N/A')}, ")
                        html.append(f"Mode: {metadata.get('mode', 'N/A')}, ")
                        html.append(f"Size: {metadata.get('size', 'N/A')}, ")
                        html.append(f"MTime: {metadata.get('mtime_iso', 'N/A')}<br>")
                html.append("</div></td>")
                html.append("</tr>")
            
            if len(results['mismatched']) > 100:
                html.append(f"<tr><td colspan='3'>... and {len(results['mismatched']) - 100} more</td></tr>")
            html.append("</table>")
        
        html.append("</body></html>")
        
        with open(output_file, 'w') as f:
            f.write("\n".join(html))
        
        return "\n".join(html)
    
    def compare(self) -> Dict[str, Any]:
        """Compare all manifests"""
        server_names = list(self.servers.keys())
        
        results = {
            "matching": [],
            "mismatched": [],
            "unique_files": {server: [] for server in server_names},
            "missing_files": {server: [] for server in server_names}
        }
        
        for file_path in sorted(self.all_files):
            metadata_by_server = {}
            
            for server, data in self.servers.items():
                if file_path in data['manifest']:
                    metadata_by_server[server] = data['manifest'][file_path]
            
            if len(metadata_by_server) == len(server_names):
                # File exists on all servers
                comparison = self.compare_metadata(file_path, metadata_by_server)
                
                if all([comparison['checksum_match'], comparison['size_match'], 
                       comparison['owner_match'], comparison['mode_match']]):
                    results['matching'].append(file_path)
                else:
                    results['mismatched'].append({
                        'path': file_path,
                        'metadata': metadata_by_server,
                        'comparison': comparison
                    })
            else:
                # File missing from some servers
                for server in server_names:
                    if server in metadata_by_server:
                        results['unique_files'][server].append(file_path)
                    else:
                        results['missing_files'][server].append(file_path)
        
        return results

def main():
    parser = argparse.ArgumentParser()
    parser.add_argument('--manifests', nargs='+', required=True)
    parser.add_argument('--output', required=True)
    parser.add_argument('--format', choices=['html', 'text', 'json'], default='html')
    args = parser.parse_args()
    
    comparer = MetadataComparer()
    comparer.load_manifests(args.manifests)
    results = comparer.compare()
    
    if args.format == 'html':
        comparer.generate_html_report(results, args.output)
    elif args.format == 'json':
        with open(args.output, 'w') as f:
            json.dump(results, f, indent=2)
    else:
        # Text format (simplified)
        with open(args.output, 'w') as f:
            f.write(f"Comparison Report - {datetime.now()}\n")
            f.write(f"Matching files: {len(results['matching'])}\n")
            f.write(f"Mismatched files: {len(results['mismatched'])}\n")
    
    print(f"Report generated: {args.output}")

if __name__ == "__main__":
    main()

