#!/usr/bin/env python3
"""
enhanced_checksum_scanner.py - Generate comprehensive manifest with file metadata
Supports multiple base paths with individual exclusion rules
"""

import os
import hashlib
import json
import sys
import fnmatch
import argparse
import pwd
import grp
from datetime import datetime
from typing import Dict, List, Optional, Any
from dataclasses import dataclass, asdict
import stat

@dataclass
class FileMetadata:
    """Complete file metadata structure"""
    checksum: str
    size: int
    owner: str
    group: str
    mode: str  # Octal permissions (e.g., '0644')
    mtime: float  # Unix timestamp
    mtime_iso: str  # Human readable
    ctime: float
    ctime_iso: str
    inode: int
    device: int
    
class EnhancedChecksumScanner:
    def __init__(self, chunk_size: int = 65536, include_metadata: bool = True):
        self.chunk_size = chunk_size
        self.include_metadata = include_metadata
        self.processed_count = 0
        self.skipped_count = 0
        self.error_count = 0
        self.warning_count = 0
        
        # Cache for UID/GID lookups
        self.uid_cache = {}
        self.gid_cache = {}
    
    def _get_username(self, uid: int) -> str:
        """Get username from UID with caching"""
        if uid not in self.uid_cache:
            try:
                self.uid_cache[uid] = pwd.getpwuid(uid).pw_name
            except (KeyError, ImportError):
                self.uid_cache[uid] = str(uid)
        return self.uid_cache[uid]
    
    def _get_groupname(self, gid: int) -> str:
        """Get group name from GID with caching"""
        if gid not in self.gid_cache:
            try:
                self.gid_cache[gid] = grp.getgrgid(gid).gr_name
            except (KeyError, ImportError):
                self.gid_cache[gid] = str(gid)
        return self.gid_cache[gid]
    
    def calculate_sha256(self, filepath: str) -> str:
        """Calculate SHA256 hash efficiently using chunked reading"""
        sha256_hash = hashlib.sha256()
        try:
            with open(filepath, "rb") as f:
                for chunk in iter(lambda: f.read(self.chunk_size), b""):
                    sha256_hash.update(chunk)
            return sha256_hash.hexdigest()
        except (IOError, OSError, PermissionError) as e:
            self.error_count += 1
            return f"ERROR:{str(e)}"
    
    def get_file_metadata(self, filepath: str, checksum: str) -> FileMetadata:
        """Collect all file metadata"""
        try:
            stat_info = os.stat(filepath)
            
            return FileMetadata(
                checksum=checksum,
                size=stat_info.st_size,
                owner=self._get_username(stat_info.st_uid),
                group=self._get_groupname(stat_info.st_gid),
                mode=oct(stat.S_IMODE(stat_info.st_mode))[2:].zfill(4),
                mtime=stat_info.st_mtime,
                mtime_iso=datetime.fromtimestamp(stat_info.st_mtime).isoformat(),
                ctime=stat_info.st_ctime,
                ctime_iso=datetime.fromtimestamp(stat_info.st_ctime).isoformat(),
                inode=stat_info.st_ino,
                device=stat_info.st_dev
            )
        except (IOError, OSError) as e:
            self.warning_count += 1
            # Return minimal metadata on error
            return FileMetadata(
                checksum=checksum,
                size=-1,
                owner="unknown",
                group="unknown",
                mode="0000",
                mtime=0,
                mtime_iso="1970-01-01T00:00:00",
                ctime=0,
                ctime_iso="1970-01-01T00:00:00",
                inode=-1,
                device=-1
            )
    
    def should_exclude(self, path: str, exclude_patterns: List[str]) -> bool:
        """Check if path matches any exclusion pattern"""
        if not exclude_patterns:
            return False
            
        path_normalized = path.replace('\\', '/')
        
        for pattern in exclude_patterns:
            # Direct match
            if fnmatch.fnmatch(path_normalized, pattern):
                return True
            # Basename match
            if fnmatch.fnmatch(os.path.basename(path_normalized), pattern):
                return True
            # Check parent directories
            path_parts = path_normalized.split(os.sep)
            for i in range(len(path_parts)):
                partial_path = os.sep.join(path_parts[:i+1])
                if fnmatch.fnmatch(partial_path, pattern):
                    return True
        return False
    
    def scan_path_config(self, config: Dict[str, Any]) -> Dict[str, Any]:
        """
        Scan a single path configuration
        Config format:
        {
            "path": "/absolute/path",
            "alias": "app_name",  # Optional, used as prefix in manifest
            "exclude": ["*/logs*", "*.tmp"],  # Optional, overrides global
            "extensions": [".py", ".js", ".conf"],  # Optional
            "max_depth": None,  # Optional, max directory depth
            "follow_symlinks": False  # Optional
        }
        """
        root_path = config['path']
        alias = config.get('alias', os.path.basename(root_path))
        exclude_patterns = config.get('exclude', [])
        extensions = config.get('extensions', [])
        max_depth = config.get('max_depth')
        follow_symlinks = config.get('follow_symlinks', False)
        
        manifest = {}
        
        if not os.path.exists(root_path):
            print(f"ERROR: Path does not exist: {root_path}", file=sys.stderr)
            return manifest
        
        # Calculate base depth for depth limiting
        base_depth = root_path.rstrip(os.sep).count(os.sep)
        
        for dirpath, dirnames, filenames in os.walk(root_path, followlinks=follow_symlinks):
            # Check depth limit
            if max_depth is not None:
                current_depth = dirpath.count(os.sep) - base_depth
                if current_depth >= max_depth:
                    dirnames.clear()  # Don't go deeper
                    print(f"Reached max depth {max_depth} at {dirpath}", file=sys.stderr)
            
            # Filter directories in-place for efficiency
            dirnames[:] = [
                d for d in dirnames 
                if not self.should_exclude(os.path.join(dirpath, d), exclude_patterns)
            ]
            
            # Skip entire directory if excluded
            if self.should_exclude(dirpath, exclude_patterns):
                self.skipped_count += len(filenames)
                continue
            
            for filename in filenames:
                full_path = os.path.join(dirpath, filename)
                
                # Skip if file matches exclusion patterns
                if self.should_exclude(full_path, exclude_patterns):
                    self.skipped_count += 1
                    continue
                
                # Filter by extension if specified
                if extensions:
                    if not any(filename.endswith(ext) for ext in extensions):
                        self.skipped_count += 1
                        continue
                
                # Calculate checksum
                checksum = self.calculate_sha256(full_path)
                
                # Get relative path from root
                relative_path = os.path.relpath(full_path, start=root_path)
                manifest_key = f"{alias}/{relative_path}"
                
                # Store metadata
                if self.include_metadata:
                    metadata = self.get_file_metadata(full_path, checksum)
                    manifest[manifest_key] = asdict(metadata)
                else:
                    manifest[manifest_key] = {"checksum": checksum}
                
                self.processed_count += 1
                
                # Progress indicator
                if self.processed_count % 1000 == 0:
                    print(f"Processed {self.processed_count} files...", file=sys.stderr)
        
        return manifest

class ConfigLoader:
    """Load and validate configuration from JSON or YAML"""
    
    @staticmethod
    def load_from_file(config_file: str) -> Dict[str, Any]:
        """Load configuration from JSON file"""
        with open(config_file, 'r') as f:
            if config_file.endswith('.json'):
                return json.load(f)
            elif config_file.endswith(('.yml', '.yaml')):
                try:
                    import yaml
                    return yaml.safe_load(f)
                except ImportError:
                    raise ImportError("PyYAML required for YAML config files")
            else:
                raise ValueError(f"Unsupported config format: {config_file}")
    
    @staticmethod
    def validate_config(config: Dict[str, Any]) -> List[str]:
        """Validate configuration and return list of errors"""
        errors = []
        
        if 'paths' not in config:
            errors.append("Missing 'paths' section in config")
            return errors
        
        for idx, path_config in enumerate(config['paths']):
            if 'path' not in path_config:
                errors.append(f"Path config #{idx} missing required 'path' field")
            
            # Validate path exists
            if 'path' in path_config and not os.path.exists(path_config['path']):
                errors.append(f"Path does not exist: {path_config['path']}")
        
        return errors

def main():
    parser = argparse.ArgumentParser(
        description='Enhanced checksum scanner with metadata support',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  # Use configuration file
  %(prog)s --config /path/to/config.json --output manifest.json
  
  # Quick scan with command line arguments
  %(prog)s --paths /opt/app1 /opt/app2 --exclude "*/logs*" "*.tmp" --output manifest.json
  
  # Disable metadata for faster scanning
  %(prog)s --config config.json --no-metadata --output checksums.json
        """
    )
    
    # Configuration options
    config_group = parser.add_mutually_exclusive_group(required=True)
    config_group.add_argument('--config', help='Configuration file (JSON or YAML)')
    config_group.add_argument('--paths', nargs='+', help='Directories to scan')
    
    # Output options
    parser.add_argument('--output', required=True, help='Output manifest file')
    parser.add_argument('--format', choices=['json', 'yaml'], default='json', 
                       help='Output format')
    
    # Scanning options
    parser.add_argument('--exclude', nargs='*', 
                       default=['*/logs*', '*/backup*', '*/tmp*', '*/cache*', '*.log', '*.tmp'],
                       help='Global exclusion patterns')
    parser.add_argument('--extensions', nargs='*', 
                       help='Only process files with these extensions')
    parser.add_argument('--max-depth', type=int, help='Maximum directory depth')
    parser.add_argument('--no-metadata', action='store_true', 
                       help='Skip metadata collection (checksum only)')
    parser.add_argument('--follow-symlinks', action='store_true',
                       help='Follow symbolic links')
    
    # Server identification
    parser.add_argument('--server-name', help='Server identifier')
    parser.add_argument('--server-role', help='Server role (e.g., prod, staging)')
    parser.add_argument('--tags', nargs='*', help='Custom tags for this scan')
    
    args = parser.parse_args()
    
    # Build configuration
    if args.config:
        # Load from file
        loader = ConfigLoader()
        config = loader.load_from_file(args.config)
        errors = loader.validate_config(config)
        if errors:
            print("Configuration errors:", file=sys.stderr)
            for error in errors:
                print(f"  - {error}", file=sys.stderr)
            sys.exit(1)
        
        paths_config = config['paths']
        global_config = config.get('global', {})
        
        # Merge command line overrides
        if args.exclude:
            global_config['exclude'] = args.exclude
        if args.extensions:
            global_config['extensions'] = args.extensions
    else:
        # Build from command line
        paths_config = [{
            'path': path,
            'alias': os.path.basename(path),
            'exclude': args.exclude,
            'extensions': args.extensions,
            'max_depth': args.max_depth,
            'follow_symlinks': args.follow_symlinks
        } for path in args.paths]
        
        global_config = {}
    
    # Initialize scanner
    scanner = EnhancedChecksumScanner(
        include_metadata=not args.no_metadata
    )
    
    # Get server identification
    server_info = {
        "hostname": os.uname().nodename if hasattr(os, 'uname') else args.server_name,
        "provided_name": args.server_name,
        "role": args.server_role,
        "tags": args.tags or [],
        "ip_address": os.popen('hostname -I 2>/dev/null').read().strip().split()[0] 
                     if os.system('which hostname >/dev/null 2>&1') == 0 else None
    }
    
    print(f"Starting scan on {server_info['hostname']}...", file=sys.stderr)
    print(f"Configuration: {len(paths_config)} path(s) to scan", file=sys.stderr)
    
    # Scan all configured paths
    full_manifest = {}
    
    for path_config in paths_config:
        # Merge with global defaults
        if 'exclude' not in path_config:
            path_config['exclude'] = global_config.get('exclude', args.exclude)
        if 'extensions' not in path_config:
            path_config['extensions'] = global_config.get('extensions', args.extensions)
        if 'max_depth' not in path_config:
            path_config['max_depth'] = global_config.get('max_depth', args.max_depth)
        
        print(f"Scanning: {path_config['path']} (alias: {path_config.get('alias', 'none')})", 
              file=sys.stderr)
        
        path_manifest = scanner.scan_path_config(path_config)
        full_manifest.update(path_manifest)
    
    # Build output data structure
    output_data = {
        "metadata": {
            "server": server_info,
            "scan_info": {
                "timestamp": datetime.now().isoformat(),
                "timestamp_unix": datetime.now().timestamp(),
                "scanner_version": "2.0",
                "include_metadata": not args.no_metadata,
                "paths_scanned": [p['path'] for p in paths_config]
            },
            "statistics": {
                "processed_files": scanner.processed_count,
                "skipped_files": scanner.skipped_count,
                "errors": scanner.error_count,
                "warnings": scanner.warning_count,
                "total_manifest_entries": len(full_manifest)
            }
        },
        "manifest": full_manifest
    }
    
    # Write output
    with open(args.output, 'w') as f:
        if args.format == 'json':
            json.dump(output_data, f, indent=2)
        elif args.format == 'yaml':
            import yaml
            yaml.dump(output_data, f, default_flow_style=False)
    
    print(f"\nScan complete!", file=sys.stderr)
    print(f"Manifest saved to {args.output}", file=sys.stderr)
    print(f"Statistics:", file=sys.stderr)
    print(f"  Processed: {scanner.processed_count}", file=sys.stderr)
    print(f"  Skipped: {scanner.skipped_count}", file=sys.stderr)
    print(f"  Errors: {scanner.error_count}", file=sys.stderr)
    print(f"  Warnings: {scanner.warning_count}", file=sys.stderr)

if __name__ == "__main__":
    main()




